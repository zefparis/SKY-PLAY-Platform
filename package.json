{
  "name": "skyplay-platform",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "api-deploy"
  ],
  "scripts": {
    "dev:web": "npm run dev --prefix apps/web",
    "dev:admin": "npm run dev --prefix apps/admin",
    "dev:api": "npm run start:dev --prefix services/api",
    "dev:realtime": "node services/realtime-gateway/src/index.js",
    "docker:check": "powershell ./scripts/check-docker.ps1",
    "build": "npm run build --workspace=api-deploy",
    "start": "npm run start --workspace=api-deploy"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  }
}
