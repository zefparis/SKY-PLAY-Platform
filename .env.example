NODE_ENV=development
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000
REALTIME_URL=ws://localhost:4001
DATABASE_URL=postgresql://skyplay:skyplay123@localhost:5433/skyplay_db
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me
STRIPE_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
PAYMENT_PROVIDER=flutterwave
AWS_REGION=eu-west-3
AWS_S3_BUCKET=skyplay-assets
CLOUDFLARE_ZONE_ID=

# Twilio Network Traversal Service (TURN)
# https://www.twilio.com/console → Network Traversal Service
# If unset, the API falls back to OpenRelay public TURN.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=
