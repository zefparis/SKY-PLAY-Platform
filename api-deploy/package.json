{
  "name": "skyplay-api-deploy",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone NestJS API for Railway",
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate && ./node_modules/.bin/nest build",
    "start": "prisma migrate deploy && node dist/main.js",
    "start:dev": "nest start --watch",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1037.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.10.0",
    "@types/multer": "^2.1.0",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.2",
    "multer": "^2.0.2",
    "node-media-server": "^4.2.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.15.2",
    "prisma": "^5.10.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.0",
    "twilio": "^6.0.0",
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.13.9"
