generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(uuid())
  cognitoSub          String?         @unique
  email               String          @unique
  username            String          @unique
  password            String?
  firstName           String?
  lastName            String?
  avatar              String?         @db.Text
  bio                 String?
  discordTag          String?
  twitchUsername      String?
  role                UserRole        @default(PLAYER)
  isVerified          Boolean         @default(false)
  isBanned            Boolean         @default(false)
  status              UserStatus      @default(OFFLINE)
  lastSeen            DateTime?
  level               Int             @default(1)
  xp                  Int             @default(0)
  fairPlayScore       Float           @default(100.0)
  gamesPlayed         Int             @default(0)
  gamesWon            Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  wallet              Wallet?
  participants        Participant[]
  matchResults        MatchResult[]
  notifications       Notification[]
  sentFriendships     Friendship[]    @relation("SentFriendships")
  receivedFriendships Friendship[]    @relation("ReceivedFriendships")
  achievements        Achievement[]

  @@index([status])
  @@index([level])
  @@index([xp])
  @@map("users")
}

enum UserRole {
  PLAYER
  ADMIN
  MODERATOR
}

enum UserStatus {
  ONLINE
  OFFLINE
  IN_GAME
  AWAY
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Decimal       @default(0) @db.Decimal(10, 2)
  currency     String        @default("XOF")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id            String            @id @default(uuid())
  walletId      String
  wallet        Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Decimal           @db.Decimal(10, 2)
  status        TransactionStatus @default(PENDING)
  reference     String?           @unique
  description   String?
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  CHALLENGE_ENTRY
  CHALLENGE_WIN
  REFUND
  COMMISSION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Challenge {
  id           String            @id @default(uuid())
  title        String
  game         String
  gameMode     String
  platform     String
  region       String            @default("EU")
  entryFee     Decimal           @db.Decimal(10, 2)
  prizePool    Decimal           @db.Decimal(10, 2)
  maxPlayers   Int
  minPlayers   Int               @default(2)
  status       ChallengeStatus   @default(OPEN)
  rules        String?
  startTime    DateTime?
  endTime      DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  participants Participant[]
  matches      Match[]

  @@map("challenges")
}

enum ChallengeStatus {
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Participant {
  id          String              @id @default(uuid())
  challengeId String
  challenge   Challenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      ParticipantStatus   @default(JOINED)
  rank        Int?
  prize       Decimal?            @db.Decimal(10, 2)
  joinedAt    DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([challengeId, userId])
  @@map("participants")
}

enum ParticipantStatus {
  JOINED
  READY
  PLAYING
  FINISHED
  DISQUALIFIED
}

model Match {
  id          String        @id @default(uuid())
  challengeId String
  challenge   Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  status      MatchStatus   @default(PENDING)
  startTime   DateTime?
  endTime     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  results     MatchResult[]

  @@map("matches")
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DISPUTED
  CANCELLED
}

model MatchResult {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int?
  proof     String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, userId])
  @@map("match_results")
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  read      Boolean            @default(false)
  data      Json?
  createdAt DateTime           @default(now())

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  CHALLENGE_INVITE
  CHALLENGE_START
  MATCH_RESULT
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PRIVATE_MESSAGE
  ACHIEVEMENT
  SYSTEM
}

model Friendship {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  sender     User             @relation("SentFriendships", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User             @relation("ReceivedFriendships", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId, status])
  @@index([receiverId, status])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String
  icon        String
  unlockedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("achievements")
}
