generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(uuid())
  cognitoSub          String?         @unique
  discordId           String?         @unique
  email               String          @unique
  username            String          @unique
  password            String?
  firstName           String?
  lastName            String?
  avatar              String?         @db.Text
  bio                 String?
  country             String?
  city                String?
  phone               String?
  nationality         String?
  discordTag          String?
  twitchUsername      String?
  role                UserRole        @default(PLAYER)
  isVerified          Boolean         @default(false)
  isBanned            Boolean         @default(false)
  banReason           String?
  bannedUntil         DateTime?
  status              UserStatus      @default(OFFLINE)
  lastSeen            DateTime?
  level               Int             @default(1)
  xp                  Int             @default(0)
  fairPlayScore       Float           @default(100.0)
  gamesPlayed         Int             @default(0)
  gamesWon            Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  wallet              Wallet?
  participants        Participant[]
  matchResults        MatchResult[]
  notifications       Notification[]
  sentFriendships     Friendship[]    @relation("SentFriendships")
  receivedFriendships Friendship[]    @relation("ReceivedFriendships")
  achievements        Achievement[]
  challengesCreated   Challenge[]
  challengeParticipations ChallengeParticipant[]
  challengeResults    ChallengeResult[]
  adminLogs           AdminLog[]
  conversationMembers  ConversationMember[]
  sentMessages         ConversationMessage[] @relation("SentMessages")
  ruleAcceptances     ChallengeRuleAcceptance[]

  // ─── KYC ───────────────────────────────────────────────────────────────────
  kycStatus        KYCStatus @default(PENDING)
  kycFirstName     String?
  kycLastName      String?
  kycIdNumber      String?
  kycIdType        String?      // CNI, PASSEPORT, PERMIS
  kycIdPhotoUrl    String?      // Cloudinary
  kycSelfieUrl     String?      // Cloudinary
  kycSubmittedAt   DateTime?
  kycVerifiedAt    DateTime?
  kycRejectedAt    DateTime?
  kycRejectReason  String?

  // ─── Limites de dépense ────────────────────────────────────────────────────
  dailyDepositLimit    Int @default(50000)
  weeklyDepositLimit   Int @default(200000)
  dailySpendLimit      Int @default(20000)
  limitsUpdatedAt      DateTime?
  limitsPendingIncrease Json?  // { field, newValue, applyAt }

  // ─── Auto-exclusion ─────────────────────────────────────────────────────────
  exclusionStatus      ExclusionStatus  @default(ACTIVE)
  exclusionUntil       DateTime?
  exclusionReason      String?
  exclusionRequestedAt DateTime?
  exclusionHistory     ExclusionHistory[]
  deviceFingerprints   DeviceFingerprint[]

  // ─── Tournaments / Leagues / Invites ─────────────────────────────────────
  tournamentsCreated        Tournament[]
  tournamentParticipations  TournamentParticipant[]
  matchesAsPlayer1          TournamentMatch[]  @relation("MatchPlayer1")
  matchesAsPlayer2          TournamentMatch[]  @relation("MatchPlayer2")
  leagueEntries             LeagueEntry[]
  sentInvites               ChallengeInvite[]  @relation("InviteFrom")
  receivedInvites           ChallengeInvite[]  @relation("InviteTo")
  linkedAccounts            LinkedAccount[]

  @@index([status])
  @@index([exclusionStatus])
  @@index([level])
  @@index([xp])
  @@map("users")
}

enum UserRole {
  PLAYER
  ADMIN
  MODERATOR
}

enum ExclusionStatus {
  ACTIVE
  SELF_EXCLUDED
  PERMANENTLY_EXCLUDED
  COOLING_OFF
}

enum KYCStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum UserStatus {
  ONLINE
  OFFLINE
  IN_GAME
  AWAY
}

model Wallet {
  id                  String        @id @default(uuid())
  userId              String        @unique
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance             Decimal       @default(0) @db.Decimal(10, 2)
  consumptionBalance  Int           @default(0)  // dépôts + crédits test
  rewardBalance       Int           @default(0)  // primes gagnées (retirables)
  currency            String        @default("XAF")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  transactions        Transaction[]

  @@map("wallets")
}

model Transaction {
  id            String            @id @default(cuid())
  walletId      String
  wallet        Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Decimal           @db.Decimal(10, 2)
  balanceBefore Int?
  balanceAfter  Int?
  status        TransactionStatus @default(PENDING)
  reference     String?           @unique
  description   String?
  flwRef        String?
  flwTxId       String?
  paymentMethod String?
  phoneNumber   String?
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([walletId])
  @@index([status])
  @@index([type])
  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  CHALLENGE_ENTRY
  CHALLENGE_WIN
  CHALLENGE_DEBIT
  CHALLENGE_CREDIT
  REFUND
  COMMISSION
  DEBIT
  CREDIT
  TEST_CREDIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Challenge {
  id          String                @id @default(cuid())
  title       String
  game        String
  type        ChallengeType
  status      ChallengeStatus       @default(OPEN)
  entryFee    Int
  maxPlayers  Int
  commission  Float
  potTotal    Int                   @default(0)
  creatorId   String
  creator     User                  @relation(fields: [creatorId], references: [id])
  participants ChallengeParticipant[]
  results     ChallengeResult[]
  matches     TournamentMatch[]
  dispute         ChallengeDispute?
  conversation    Conversation?
  ruleAcceptances ChallengeRuleAcceptance[]
  invites         ChallengeInvite[]
  createdAt       DateTime              @default(now())
  startedAt   DateTime?
  endedAt     DateTime?
  expiresAt   DateTime
  refundPolicy RefundPolicy @default(STANDARD)

  @@index([status])
  @@index([game])
  @@index([type])
  @@index([createdAt])
  @@map("challenges")
}

model ChallengeParticipant {
  id                   String         @id @default(cuid())
  challengeId          String
  userId               String
  challenge            Challenge      @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt             DateTime       @default(now())
  hasPaid              Boolean        @default(false)
  rank                 Int?
  winnings             Int?
  winningsStatus       WinningsStatus @default(PENDING)
  winningsReviewAt     DateTime?
  winningsApprovedAt   DateTime?
  winningsRejectedAt   DateTime?
  winningsRejectReason String?

  @@unique([challengeId, userId])
  @@index([userId])
  @@index([winningsStatus])
  @@map("challenge_participants")
}

model ChallengeResult {
  id            String    @id @default(cuid())
  challengeId   String
  userId        String
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  declaredRank    Int
  screenshotUrl   String?
  dataSource      ResultSource @default(SCREENSHOT)
  externalMatchId String?
  submittedAt     DateTime     @default(now())

  @@unique([challengeId, userId])
  @@index([challengeId])
  @@map("challenge_results")
}

model ChallengeDispute {
  id          String        @id @default(cuid())
  challengeId String        @unique
  challenge   Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  reason      String
  status      DisputeStatus @default(PENDING)
  adminNote   String?
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([status])
  @@map("challenge_disputes")
}

enum ChallengeType {
  DUEL
  SMALL_CHALLENGE
  STANDARD
  MEDIUM_TOURNAMENT
  BIG_TOURNAMENT
  PREMIUM_TOURNAMENT
}

enum ChallengeStatus {
  OPEN
  FULL
  IN_PROGRESS
  VALIDATING
  COMPLETED
  DISPUTED
  CANCELLED
}

enum DisputeStatus {
  PENDING
  REVIEWING
  RESOLVED
}

enum ResultSource {
  SCREENSHOT
  STEAM_API
  EPIC_API
}

// ─── BYOG — LINKED GAMING ACCOUNTS ──────────────────────────────────────────

enum GameProvider {
  STEAM
  EPIC
  DISCORD
  TWITCH
}

model LinkedAccount {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     GameProvider
  externalId   String
  username     String?
  avatarUrl    String?
  profileUrl   String?
  accessToken  String?      // AES-256-GCM encrypted
  refreshToken String?      // AES-256-GCM encrypted
  expiresAt    DateTime?
  isVerified   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([provider, externalId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("linked_accounts")
}

enum WinningsStatus {
  PENDING
  AUTO_APPROVED
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum RefundPolicy {
  STANDARD
  NO_REFUND
  PARTIAL
}

model Participant {
  id          String              @id @default(uuid())
  challengeId String
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      ParticipantStatus   @default(JOINED)
  rank        Int?
  prize       Decimal?            @db.Decimal(10, 2)
  joinedAt    DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([challengeId, userId])
  @@map("participants")
}

enum ParticipantStatus {
  JOINED
  READY
  PLAYING
  FINISHED
  DISQUALIFIED
}

model Match {
  id          String        @id @default(uuid())
  status      MatchStatus   @default(PENDING)
  startTime   DateTime?
  endTime     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  results     MatchResult[]

  @@map("matches")
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DISPUTED
  CANCELLED
}

model MatchResult {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int?
  proof     String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, userId])
  @@map("match_results")
}

model Notification {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  read      Boolean            @default(false)
  data      Json?
  createdAt DateTime           @default(now())

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  CHALLENGE_INVITE
  CHALLENGE_START
  MATCH_RESULT
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PRIVATE_MESSAGE
  ACHIEVEMENT
  SYSTEM
  CHALLENGE_FULL
  CHALLENGE_WON
  CHALLENGE_LOST
  CHALLENGE_DISPUTED
  CHALLENGE_RESOLVED
  KYC_SUBMITTED
  KYC_VERIFIED
  KYC_REJECTED
  REFUND
  WINNINGS_REVIEW
}

model Friendship {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  sender     User             @relation("SentFriendships", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User             @relation("ReceivedFriendships", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId, status])
  @@index([receiverId, status])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String
  icon        String
  unlockedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("achievements")
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String?
  targetType String?
  details    Json?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_logs")
}

// ─── CHAT ────────────────────────────────────────────────────────────────────

model Conversation {
  id          String               @id @default(cuid())
  type        ConversationType
  name        String?
  challengeId String?              @unique
  challenge   Challenge?           @relation(fields: [challengeId], references: [id])
  members     ConversationMember[]
  messages    ConversationMessage[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([type])
  @@map("conversations")
}

enum ConversationType {
  DM
  CHALLENGE
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

model ConversationMessage {
  id             String           @id @default(cuid())
  conversationId String
  authorId       String?
  content        String           @db.Text
  type           MessageType      @default(TEXT)
  imageUrl       String?          @db.Text
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         User?            @relation("SentMessages", fields: [authorId], references: [id])
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
  @@index([authorId])
  @@map("conversation_messages")
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

// ─── EXCLUSION HISTORY ───────────────────────────────────────────────────────

model ExclusionHistory {
  id          String          @id @default(cuid())
  userId      String
  type        ExclusionStatus
  duration    String
  startedAt   DateTime        @default(now())
  endsAt      DateTime?
  reason      String?
  requestedBy String
  user        User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("exclusion_history")
}

// ─── DEVICE FINGERPRINT ─────────────────────────────────────────────────────

model DeviceFingerprint {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String
  userAgent   String?
  language    String?
  timezone    String?
  screen      String?
  ipAddress   String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @updatedAt
  isFlagged   Boolean  @default(false)
  flagReason  String?
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, fingerprint])
  @@index([fingerprint])
  @@index([userId])
  @@index([ipAddress])
  @@map("device_fingerprints")
}

// ─── RULE ACCEPTANCE ─────────────────────────────────────────────────────────

model ChallengeRuleAcceptance {
  id           String    @id @default(cuid())
  userId       String
  challengeId  String
  rulesVersion String
  rulesHash    String
  acceptedAt   DateTime  @default(now())
  ipAddress    String?
  userAgent    String?
  user         User      @relation(fields: [userId], references: [id])
  challenge    Challenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
  @@index([challengeId])
  @@map("challenge_rule_acceptances")
}

// ─── TOURNAMENTS ─────────────────────────────────────────────────────────────

model Tournament {
  id            String                 @id @default(cuid())
  title         String
  game          String
  type          TournamentType
  status        TournamentStatus       @default(DRAFT)
  format        TournamentFormat
  entryFee      Int
  maxPlayers    Int
  commission    Float
  potTotal      Int                    @default(0)
  standingsJson Json?
  creatorId     String
  creator       User                   @relation(fields: [creatorId], references: [id])
  participants  TournamentParticipant[]
  pools         Pool[]
  matches       TournamentMatch[]
  league        League?                @relation(fields: [leagueId], references: [id])
  leagueId      String?
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@map("tournaments")
}

enum TournamentType {
  SIMPLE
  PREMIUM_CLUBS
  PREMIUM_NATIONS
  CHAMPIONSHIP
}

enum TournamentStatus {
  DRAFT
  OPEN
  POOL_PHASE
  KNOCKOUT_PHASE
  COMPLETED
  CANCELLED
}

enum TournamentFormat {
  POOLS_THEN_KNOCKOUT
  DOUBLE_ROUND_ROBIN
  SINGLE_ELIMINATION
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  poolId       String?
  pool         Pool?      @relation(fields: [poolId], references: [id])
  teamName     String?
  nation       String?
  points       Int        @default(0)
  goalsFor     Int        @default(0)
  goalsAgainst Int        @default(0)
  wins         Int        @default(0)
  draws        Int        @default(0)
  losses       Int        @default(0)
  yellowCards  Int        @default(0)
  redCards     Int        @default(0)
  seed         Int?
  eliminated   Boolean    @default(false)
  finalRank    Int?
  winnings     Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([tournamentId, userId])
  @@map("tournament_participants")
}

model Pool {
  id           String                  @id @default(cuid())
  tournamentId String
  tournament   Tournament              @relation(fields: [tournamentId], references: [id])
  name         String
  participants TournamentParticipant[]
  matches      TournamentMatch[]
  createdAt    DateTime                @default(now())

  @@map("pools")
}

model TournamentMatch {
  id           String       @id @default(cuid())
  tournamentId String?
  tournament   Tournament?   @relation(fields: [tournamentId], references: [id])
  poolId       String?
  pool         Pool?        @relation(fields: [poolId], references: [id])
  phase        MatchPhase
  round        Int
  player1Id    String
  player2Id    String
  player1      User         @relation("MatchPlayer1", fields: [player1Id], references: [id])
  player2      User         @relation("MatchPlayer2", fields: [player2Id], references: [id])
  winnerId     String?
  score1       Int?
  score2       Int?
  yellowCards1 Int?
  yellowCards2 Int?
  redCards1    Int?
  redCards2    Int?
  screenshot1  String?
  screenshot2  String?
  status         TMatchStatus @default(PENDING)
  scheduledAt    DateTime?
  playedAt       DateTime?
  deadlineAt     DateTime?
  walkedOver     Boolean      @default(false)
  walkoverUserId String?
  streamUrl      String?
  streamType     StreamType?
  challengeId    String?
  challenge      Challenge?   @relation(fields: [challengeId], references: [id])
  createdAt      DateTime     @default(now())

  @@map("tournament_matches")
  @@index([challengeId])
}

enum MatchPhase {
  POOL
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
  CHAMPIONSHIP_ROUND
}

enum TMatchStatus {
  PENDING
  INVITED
  IN_PROGRESS
  AWAITING_RESULTS
  DISPUTED
  COMPLETED
  WALKOVER
}

enum StreamType {
  YOUTUBE
  TWITCH
  FACEBOOK
}

// ─── LEAGUES ─────────────────────────────────────────────────────────────────

model League {
  id          String        @id @default(cuid())
  tier        LeagueTier
  season      Int
  game        String
  startsAt    DateTime
  endsAt      DateTime
  entries     LeagueEntry[]
  tournaments Tournament[]
  createdAt   DateTime      @default(now())

  @@map("leagues")
}

enum LeagueTier {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  LEGEND
  GLORY
}

model LeagueEntry {
  id        String  @id @default(cuid())
  leagueId  String
  league    League  @relation(fields: [leagueId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  points    Int     @default(0)
  rank      Int?
  promoted  Boolean @default(false)
  relegated Boolean @default(false)

  @@unique([leagueId, userId])
  @@map("league_entries")
}

// ─── CHALLENGE INVITES ────────────────────────────────────────────────────────

model ChallengeInvite {
  id          String       @id @default(cuid())
  challengeId String
  challenge   Challenge    @relation(fields: [challengeId], references: [id])
  fromUserId  String
  fromUser    User         @relation("InviteFrom", fields: [fromUserId], references: [id])
  toUserId    String
  toUser      User         @relation("InviteTo", fields: [toUserId], references: [id])
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  @@map("challenge_invites")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// ─── ADVERTISEMENTS ──────────────────────────────────────────────────────────

model Advertisement {
  id          String   @id @default(cuid())
  title       String
  type        AdType
  mediaUrl    String
  targetUrl   String?
  advertiser  String
  game        String?
  country     String?
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean  @default(true)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("advertisements")
}

enum AdType {
  VIDEO_PRE
  VIDEO_POST
  BANNER
  OVERLAY
  POPUP
  NATIVE
  SPONSORED_EVENT
}
